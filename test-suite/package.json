{
    "name": "firebase-test-suite",
    "version": "1.0.0",
    "description": "Tests for firebase (emulator)",
    "private": true,
    "scripts": {
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "test:java-emulator": "f() { firebase emulators:exec --only firestore \"NODE_OPTIONS='--experimental-vm-modules' jest --maxConcurrency 1$(printf ' %q' \"$@\")\"; }; f",
        "test:rust-emulator": "f() { export FIRESTORE_EMULATOR_HOST=127.0.0.1:8080; RUST_LOG=\"${RUST_LOG:=OFF}\" ../target/debug/firestore-emulator & PID=$!; RUST_EMULATOR=true NODE_OPTIONS='--experimental-vm-modules' jest \"$@\"; RET=$?; kill -INT $PID; return $RET; }; f",
        "build:rust": "cd .. && cargo build",
        "lint": "eslint tests && prettier -c tests"
    },
    "license": "UNLICENSED",
    "dependencies": {
        "@google-cloud/firestore": "^8.3.0",
        "@skunkteam/sherlock": "^8.0.0",
        "@skunkteam/sherlock-utils": "^8.0.0",
        "@types/lodash": "^4.17.24",
        "@types/ms": "^2.1.0",
        "lodash": "^4.17.21",
        "ms": "^2.1.3"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.5",
        "firebase-tools": "^15.9.0",
        "jest": "^30.1.3",
        "jest-extended": "^7.0.0",
        "prettier": "^3.5.3",
        "ts-jest": "^29.3.4",
        "typescript": "^5.8.3"
    }
}
